                                         "subject":  "=Stock Portfolio Update - {{ $now.toFormat(\"MMM d, yyyy h:mm a\") }}",
                                         "message":  "<!DOCTYPE html>\n<html>\n<head><meta charset=\"UTF-8\"></head>\n<body style=\"margin:0;padding:0;background:#f0f4f8;font-family:Helvetica,Arial,sans-serif;\">\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"padding:24px 16px;background:#f0f4f8;\">\n<tr><td align=\"center\">\n<table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:600px;width:100%;\">\n\n  <!-- ACCENT TOP -->\n  <tr><td style=\"background:linear-gradient(90deg,#2563eb,#7c3aed,#0891b2);height:4px;border-radius:12px 12px 0 0;\"></td></tr>\n\n  <!-- HEADER -->\n  <tr><td style=\"background:#1e2d4f;padding:32px 40px;text-align:center;\">\n    <p style=\"margin:0 0 8px;font-size:11px;font-weight:700;letter-spacing:3px;color:#60a5fa;\">PORTFOLIO MONITOR</p>\n    <h1 style=\"margin:0 0 8px;font-size:28px;font-weight:800;color:#ffffff;\">Daily Market Brief</h1>\n    <p style=\"margin:0;font-size:13px;color:#94a3b8;\">{{ $now.toFormat(\"EEEE, MMMM d, yyyy\") }} | {{ $now.toFormat(\"h:mm a\") }} IST</p>\n  </td></tr>\n\n  <!-- STATS BAR -->\n  <tr><td style=\"background:#162040;padding:12px 40px;border-top:1px solid #1e3a5f;\">\n    <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr>\n\n      <td align=\"center\" width=\"33%\" style=\"border-right:1px solid #1e3a5f;padding:8px;\">\n        <p style=\"margin:0;font-size:10px;letter-spacing:2px;color:#64748b;\">MARKET SENTIMENT</p>\n        <p style=\"margin:4px 0 0;font-size:14px;font-weight:700;color:{{ $json.sentimentColor }};\">{{ $json.sentimentEmoji }} {{ $json.overallSentiment }}</p>\n        <p style=\"margin:2px 0 0;font-size:10px;color:#64748b;\">Bullish: {{ $json.bullishCount }} &nbsp; Neutral: {{ $json.neutralCount }} &nbsp; Bearish: {{ $json.bearishCount }}</p>\n      </td>\n\n      <td align=\"center\" width=\"33%\" style=\"border-right:1px solid #1e3a5f;padding:8px;\">\n        <p style=\"margin:0 0 6px;font-size:10px;letter-spacing:2px;color:#64748b;\">HOT STOCKS</p>\n        {{ $json.hotStocksHTML }}\n      </td>\n\n      <td align=\"center\" width=\"33%\" style=\"padding:8px;\">\n        <p style=\"margin:0;font-size:10px;letter-spacing:2px;color:#64748b;\">COVERAGE</p>\n        <p style=\"margin:4px 0 0;font-size:14px;font-weight:700;color:#a78bfa;\">{{ $json.total }} STOCKS</p>\n        <p style=\"margin:2px 0 0;font-size:10px;color:#64748b;\">NSE / BSE</p>\n      </td>\n\n    </tr></table>\n  </td></tr>\n\n  <!-- CONTENT -->\n  <tr><td style=\"background:#ffffff;padding:32px 40px;border-left:1px solid #e2e8f0;border-right:1px solid #e2e8f0;\">\n    {{ $json.htmlContent }}\n  </td></tr>\n\n  <!-- FOOTER -->\n  <tr><td style=\"background:#1e2d4f;padding:20px 40px;text-align:center;border-radius:0 0 12px 12px;\">\n    <p style=\"margin:0 0 4px;font-size:13px;font-weight:600;color:#94a3b8;\">AI Portfolio Monitor</p>\n    <p style=\"margin:0;font-size:11px;color:#475569;\">{{ $now.toFormat(\"EEEE, MMMM d, yyyy\") }} | {{ $now.toFormat(\"h:mm a\") }} IST</p>\n  </td></tr>\n\n  <!-- ACCENT BOTTOM -->\n  <tr><td style=\"background:linear-gradient(90deg,#2563eb,#7c3aed,#0891b2);height:3px;border-radius:0 0 8px 8px;\"></td></tr>\n\n</table>\n</td></tr>\n</table>\n</body>\n</html>",
                                         "options":  {
                                                         "senderName":  "AI Portfolio Monitor"
                                                     }
                                     },
