                  {
                      "parameters":  {
                                         "chatId":  "={{ $env.TELEGRAM_CHAT_ID }}",
                                         "text":  "=*Portfolio Update - {{ $now.toFormat(\"MMM d, h:mm a\") }}*  {{ $json.output.slice(0, 3000) }}  _Powered by n8n_",
                                         "additionalFields":  {
                                                                  "parse_mode":  "Markdown"
                                                              }
                                     },
                      "type":  "n8n-nodes-base.telegram",
                      "typeVersion":  1.2,
                      "position":  [
                                       4112,
                                       960
                                   ],
                      "id":  "8180e75b-72b7-4833-a71b-233336433956",
                      "name":  "Send a text message",
                      "webhookId":  "b973f9df-cb73-414b-b976-848a69ec4432",
                      "credentials":  {
                                          "telegramApi":  {
                                                              "name":  "Telegram bot account"
                                                          }
                                      }
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const stockUpdates = $input.first().json.stockUpdates;\n\nconst grouped = {};\nfor (const item of stockUpdates) {\n  const ticker = item.ticker;\n  if (!grouped[ticker]) grouped[ticker] = [];\n  grouped[ticker].push({\n    title: item.title,\n    pubDate: item.pubDate,\n    link: item.link\n  });\n}\n\n// Sort by date and take latest 3\nconst result = {};\nfor (const ticker of Object.keys(grouped)) {\n  result[ticker] = grouped[ticker]\n    .sort((a, b) => new Date(b.pubDate) - new Date(a.pubDate))\n    .slice(0, 4);\n}\n\nreturn [{ json: { stockUpdates: result } }];"
                                     },
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       3328,
                                       1152
                                   ],
                      "id":  "5acbf0e7-407f-4f48-b123-675193a497e7",
                      "name":  "Sorting and selecting info"
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const md = $input.first().json.output;\nconst stockUpdates = $('Sorting and selecting info').first().json.stockUpdates || {};\nconst headlineMap = {};\nfor (const [ticker, articles] of Object.entries(stockUpdates)) {\n  headlineMap[ticker] = Array.isArray(articles) ? articles : [];\n}\n\n// Compute sentiment\nconst bullishCount = (md.match(/\\*\\*Sentiment:\\*\\* Bullish/g) || []).length;\nconst bearishCount = (md.match(/\\*\\*Sentiment:\\*\\* Bearish/g) || []).length;\nconst neutralCount = (md.match(/\\*\\*Sentiment:\\*\\* Neutral/g) || []).length;\nconst total = bullishCount + bearishCount + neutralCount;\n\nlet overallSentiment, sentimentColor, sentimentEmoji;\nif (bullishCount > bearishCount && bullishCount > neutralCount) {\n  overallSentiment = 'BULLISH'; sentimentColor = '#34d399'; sentimentEmoji = 'UP';\n} else if (bearishCount > bullishCount) {\n  overallSentiment = 'BEARISH'; sentimentColor = '#f87171'; sentimentEmoji = 'DOWN';\n} else {\n  overallSentiment = 'NEUTRAL'; sentimentColor = '#94a3b8'; sentimentEmoji = '-';\n}\n\n// Hot stocks\nconst bullishMatches = [...md.matchAll(/## ([A-Z&]+)[\\s\\S]*?\\*\\*Sentiment:\\*\\* Bullish/g)];\nconst bullishTickers = bullishMatches.map(m => ({\n  ticker: m[1].trim(),\n  articleCount: (headlineMap[m[1].trim()] || []).length\n})).sort((a, b) => b.articleCount - a.articleCount);\n\nconst hotStocksHTML = bullishTickers.slice(0, 3).map(s =>\n  `<span style=\"background:#0f3a2a;color:#34d399;font-size:11px;font-weight:700;padding:3px 8px;border-radius:12px;margin:2px;display:inline-block;\">HOT ${s.ticker}</span>`\n).join(' ') || '<span style=\"color:#64748b;font-size:11px;\">None today</span>';\n\n// Clean up markdown - remove excessive blank lines first\nconst cleaned = md.replace(/\\n{3,}/g, '\\n\\n').trim();\n\n// Split into sections by ## headers\nconst sections = cleaned.split(/^(?=## )/gm);\n\nlet html = '';\n\nfor (const section of sections) {\n  if (!section.trim()) continue;\n\n  const lines = section.trim().split('\\n');\n  const header = lines[0].replace(/^## /, '').trim();\n  const body = lines.slice(1).join('\\n').trim();\n\n  if (header === 'Portfolio Overview') {\n    const bodyHTML = body\n      .replace(/\\*\\*(.+?)\\*\\*/g, '<strong>$1</strong>')\n      .replace(/\\n/g, ' ');\n    html += `\n      <div style=\"background:#f0f7ff;border-left:3px solid #2563eb;border-radius:0 6px 6px 0;padding:12px 16px;margin:0 0 16px;\">\n        <p style=\"margin:0 0 4px;font-size:10px;font-weight:700;letter-spacing:2px;color:#2563eb;\">PORTFOLIO OVERVIEW</p>\n        <p style=\"margin:0;font-size:13px;color:#334155;line-height:1.6;\">${bodyHTML}</p>\n      </div>`;\n    continue;\n  }\n\n  // Stock section\n  const headlines = headlineMap[header] || [];\n\n  // Parse body into summary and sentiment\n  const summaryMatch = body.match(/\\*\\*Summary:\\*\\*\\s*([\\s\\S]*?)(?=\\*\\*Sentiment:|$)/);\n  const sentimentMatch = body.match(/\\*\\*Sentiment:\\*\\*\\s*([^\\n]+)/);\n\n  const summaryText = summaryMatch \n    ? summaryMatch[1].trim().replace(/\\n/g, ' ').replace(/\\*\\*(.+?)\\*\\*/g, '<strong>$1</strong>')\n    : body.replace(/\\n/g, ' ').replace(/\\*\\*(.+?)\\*\\*/g, '<strong>$1</strong>');\n\n  const sentimentRaw = sentimentMatch ? sentimentMatch[1].trim() : '';\n  let sentBg = '#f8fafc', sentBorder = '#e2e8f0', sentTextColor = '#475569', sentIcon = '-', sentLabel = 'NEUTRAL';\n  if (sentimentRaw.toLowerCase().startsWith('bullish')) {\n    sentBg = '#f0fdf4'; sentBorder = '#bbf7d0'; sentTextColor = '#166534'; sentIcon = 'UP'; sentLabel = 'BULLISH';\n  } else if (sentimentRaw.toLowerCase().startsWith('bearish')) {\n    sentBg = '#fef2f2'; sentBorder = '#fecaca'; sentTextColor = '#991b1b'; sentIcon = 'DOWN'; sentLabel = 'BEARISH';\n  }\n  const sentimentReason = sentimentRaw.replace(/^(Bullish|Bearish|Neutral)\\s*[--]?\\s*/i, '');\n\n  // Links\n  const linksHTML = headlines.map(h => {\n    const date = h.pubDate ? new Date(h.pubDate).toLocaleDateString('en-IN', {day:'numeric', month:'short', year:'numeric'}) : '';\n    return `<a href=\"${h.link || '#'}\" target=\"_blank\" style=\"display:block;text-decoration:none;padding:5px 8px;margin-bottom:4px;background:#f0f7ff;border-radius:5px;\">\n      <span style=\"font-size:11px;color:#1d4ed8;font-weight:500;line-height:1.3;display:block;\">Source: ${h.title || 'Read article'}</span>\n      <span style=\"font-size:10px;color:#94a3b8;\">Date: ${date}</span>\n    </a>`;\n  }).join('');\n\n  html += `\n    <div style=\"border:1px solid #e2e8f0;border-radius:8px;padding:12px 16px;margin-bottom:12px;\">\n      <p style=\"margin:0 0 8px;font-size:12px;font-weight:700;letter-spacing:2px;color:#6366f1;\">${header}</p>\n      <p style=\"margin:0 0 8px;font-size:13px;color:#334155;line-height:1.6;\">${summaryText}</p>\n      <div style=\"background:${sentBg};border:1px solid ${sentBorder};border-radius:6px;padding:6px 10px;margin-bottom:${linksHTML ? '8px' : '0'};\">\n        <span style=\"font-size:12px;color:${sentTextColor};font-weight:700;\">${sentIcon} ${sentLabel}</span>\n        <span style=\"font-size:12px;color:${sentTextColor};\"> - ${sentimentReason}</span>\n      </div>\n      ${linksHTML ? `<div style=\"margin-top:6px;\"><p style=\"margin:0 0 4px;font-size:10px;font-weight:700;letter-spacing:1px;color:#94a3b8;\">SOURCE ARTICLES</p>${linksHTML}</div>` : ''}\n    </div>`;\n}\n\nreturn [{ json: {\n  htmlContent: html,\n  overallSentiment,\n  sentimentColor,\n  sentimentEmoji,\n  bullishCount,\n  bearishCount,\n  neutralCount,\n  total,\n  hotStocksHTML\n}}];"
                                     },
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
